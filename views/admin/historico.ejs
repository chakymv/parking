<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Histórico</title>
  <link rel="stylesheet" href="/admin/css/estilo.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css">
  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
</head>
<body>
  <%- include('header') %>
  <main>
    <div class="contenido-principal">
      <h1 class="centrar">Histórico de Entradas y Salidas</h1>
      <p class="centrar">Consulta el historial de movimientos de vehículos en el parqueadero.</p>
      <hr class="linea-windows">

      <div class="filtros">
        <input type="text" id="buscadorGeneral" class="input-filtro" placeholder="Buscar en el histórico...">
      </div>

      <table id="historico-table" class="datatable tabla-usuarios" style="width:100%">
        <thead>
          <tr>
            <th>Placa</th>
            <th>Vehículo (Marca, Modelo, Color)</th>
            <th>Tipo</th>
            <th>Fecha del Evento</th>
            <th>Celda</th>
          </tr>
        </thead>
        <tbody>
          <!-- Los datos se cargarán aquí dinámicamente -->
        </tbody>
      </table>
    </div>
  </main>

  <script>
    $(document).ready(function() {
      const table = $('#historico-table').DataTable({
        "ajax": {
          "url": "/api/historial_parqueo", // Asumiendo que este es tu endpoint para el histórico
          "dataSrc": "",
          "error": function (jqXHR, textStatus, errorThrown) {
            // Esto se activará si hay un error en la petición AJAX
            console.error("Error de Ajax:", textStatus, errorThrown);
            console.error("Respuesta del servidor:", jqXHR.responseText);
            // Opcional: Mostrar un mensaje de error más amigable en la tabla
            $('#historico-table_processing').hide();
            $('#historico-table tbody').html('<tr><td colspan="5" class="centrar" style="color:red;">Error al cargar los datos. Revise la consola del navegador (F12) para más detalles.</td></tr>');
          }
        },
        "columns": [
          { "data": "placa" },
          { 
            "data": null,
            "render": function(data, type, row) {
              // Combina campos para mostrar detalles del vehículo
              return `${row.marca || ''}, ${row.modelo || ''}, ${row.color || ''}`;
            }
          },
          { "data": "tipo" },
          {
            "data": "fecha_hora",
            "render": function(data) {
              // Formatear la fecha para que sea legible
              return data ? new Date(data).toLocaleString('es-CO') : 'N/A';
            }
          },
          { "data": "celda_id" }
        ],
        "language": {
          "url": "https://cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json"
        },
        responsive: true,
        "order": [[ 3, "desc" ]] // Ordenar por fecha de entrada (la 4ta columna) de más reciente a más antiguo
      });

      // Funcionalidad de búsqueda general
      $('#buscadorGeneral').on('keyup', function(){
        table.search(this.value).draw();
      });
    });
  </script>
</body>
</html>
